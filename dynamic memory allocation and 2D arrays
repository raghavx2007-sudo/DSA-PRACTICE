Print column sum
#include <stdio.h>
#include <stdlib.h>
void colsum(int **arr,int n){
      for(int row=0;row<n;row++){
            int sum=0;
            for(int col=0;col<n;col++){
                   sum+=arr[col][row];
            }
            printf("%d",sum);
      }
}
int main()
{
    int n;
    scanf("%d",&n);
    int **arr=(int**)malloc(n*sizeof(int*));
    for(int i=0;i<n;i++){
          *(arr+i)=(int*)malloc(n*sizeof(int));
    }
    for(int row=0;row<n;row++){
            for(int col=0;col<n;col++){
                  scanf("%d",*(arr+row)+col);
            }
      }
   colsum(arr,n);
    return 0;
}
Row max
#include <stdio.h>
#include <stdlib.h>
void colsum(int **arr,int n){
      for(int row=0;row<n;row++){
            int max=0;
            for(int col=0;col<n;col++){
                  if(arr[row][col]>max)max=arr[row][col];
            }
            printf("%d ",max);
      }
}
