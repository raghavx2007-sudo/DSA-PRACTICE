1. Store and Print Student Details - Basic Structure
Sample Input:
101 Arjun 19 87.5
Sample Output:
Roll No: 101
Name: Arjun
Age: 19
Marks: 87.50
PROGRAM:
#include <stdio.h>
#include <stdlib.h>
struct student{
      int rollnum;
      char name[100];
      double marks;
};
int main()
{
   struct student *s1;
   s1=(struct student*)malloc(sizeof(struct student));
   printf("Enter Student Roll Number :\n");
   scanf("%d",&s1->rollnum);
   printf("Enter Student Name :\n");
   scanf(" %[^\n]",s1->name);
   printf("Enter Student Age :\n");
   scanf("%d",&s1->age);
   printf("Enter Student mark :\n");
   scanf("%lf",&s1->marks);
   printf("Student Details");
   printf("Roll No: %d\n",s1->rollnum);
   printf("Name : %s\n",s1->name);
   printf("Age : %d\n",s1->age); 
   printf("Marks : %.2lf\n",s1->marks);
   

    return 0;
}
2. Calculate Average Marks of Students - Array of Structures
Sample Input:
3
1 Arjun 80
2 Banu 90
3 Charu 70
Sample Output:
Average Marks: 80.00
PROGRAM:
#include <stdio.h>
#include <stdlib.h>
struct student{
      int rollnum;
      char name[100];
      double marks;
};
int main()
{
   int n;
   scanf("%d",&n);
   struct student *s;
   s=(struct student*)malloc(sizeof(struct student));
   for(int i=0;i<n;i++){
   printf("Enter Student %d Roll Number :\n",i+1);
   scanf("%d",&(s+i)->rollnum);
   printf("Enter Student Name :\n");
   scanf(" %[^\n]",(s+i)->name);
   printf("Enter Student mark :\n");
   scanf("%lf",&(s+i)->marks);

   }
double avg=0;
   for(int i=0;i<n;i++){
         avg+=(s+i)->marks;
   }
   printf("Average Marks : %.2lf",avg/2);
    return 0;
}
