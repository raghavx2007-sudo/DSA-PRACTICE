      struct node *newnode = (struct node*)malloc(sizeof(struct node));
      newnode -> data = val;
      newnode -> next = NULL;
      newnode -> prev = NULL;
      if(head == NULL){
            head = newnode;
      }
      else{
            struct node *temp = head;
            while(temp -> next){
                  temp = temp -> next;
            }
            temp -> next = newnode;
            newnode -> prev = temp;
      }
}
